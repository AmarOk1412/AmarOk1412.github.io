    <item>
      <title>Brussels</title>
      <link>https://enconn.fr/logs/brussels/</link>
      <pubDate>Tue, 06 Feb 2018 00:00:00 +0000</pubDate><author>contact@enconn.fr (Sébastien Blin)</author>
